{

  // ********** settings git / gitlens **********

  // disable "blame hover", to remove visual noise
 "gitlens.currentLine.enabled": false,

 // ********** settings for cspell *************
  // don't show spelling errors in the problem panel, hints dint appear in the problem panel
  "cSpell.diagnosticLevel": "Hint",
  // only check spelling in enabled file types
  "cSpell.checkOnlyEnabledFileTypes": true,
  "cSpell.enabledFileTypes": {
    "*": false,
    "markdown": true,
    "plaintext": true,
    "r": true,
    "qmd": true,
  },
  "cSpell.useGitignore": true, // respects .gitignore
  // this allows to ignore paths
  // "cSpell.ignorePaths": [
  //   "**/revdep/**"
  // ]
  // whitelist for paths
  // "cSpell.files": [
  //   "**/*.{md,R,Rmd,Rd}",
  //   "man/**"
  // ]
  "cSpell.languageSettings": [
    {
      "languageId": "r",
      "includeRegExpList": [
        // include comments (also roxygen): matches "#'" and everything until end-of-line (g=all matches, m=multiline)
        "/#.*$/gm"
      ]
    }
  ],

 // ********** settings for R *************

  // format on save so we dont have to manually format, use AIR for formatting
  "[r]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "Posit.air-vscode",
    // disable hover for R, to remove visual noise
    "editor.hover.enabled": false
  },

  // ********** settings for C / C++ **********

  "[c]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "[cpp]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  }
}

